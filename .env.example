# Copy to .env and fill in. Phase 1 runs fully on MOCK_GENERATION=true with no keys.

# --- Generation: keep true until you're ready to spend money ---
MOCK_GENERATION=true

# --- Provider keys (server-side only; leave blank in mock mode) ---
# OpenAI powers gpt-5.4-nano; Anthropic powers claude-haiku-4-6. Set whichever
# LLM(s) you intend to use (a project picks one). ElevenLabs = narration.
# Generation: fal = FLUX/Kling/Seedance; GOOGLE = Veo (image/text-to-video) direct.
FAL_KEY=
GOOGLE_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
ELEVENLABS_API_KEY=

# --- LLM default (per-project pick overrides; options: gpt-5.4-nano, claude-haiku-4-6) ---
DEFAULT_LLM=gpt-5.4-nano

# --- Infra (defaults match docker-compose; override only if needed) ---
DATABASE_URL=postgresql+psycopg2://storyforge:storyforge@postgres:5432/storyforge
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
MINIO_ENDPOINT=minio:9000
MINIO_PUBLIC_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=storyforge
MINIO_SECRET_KEY=storyforge-secret
MINIO_BUCKET=storyforge
FRONTEND_ORIGIN=http://localhost:5173
